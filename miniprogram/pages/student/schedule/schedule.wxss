.page { padding-bottom: 60px; }

.week-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: #fff;
  margin: 0 0 8px;
}
.nav-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  font-weight: 600;
  color: #4f6ef7;
}
.nav-btn:active { background: #e5e7eb; }
.week-label {
  font-size: 15px;
  font-weight: 600;
  color: #1a1a1a;
}

.today-btn-wrap {
  padding: 0 16px;
  margin-bottom: 8px;
}
.today-btn-wrap .btn { width: 70px; }

.schedule-scroll {
  height: calc(100vh - 220px);
  padding: 0 8px;
}

.schedule-grid {
  display: flex;
  flex-direction: column;
}

.grid-row {
  display: flex;
  align-items: stretch;
  min-height: 50px;
}

.header-row {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #f5f5f5;
}

.time-header {
  width: 50px;
  min-width: 50px;
}

.time-label {
  width: 50px;
  min-width: 50px;
  font-size: 11px;
  color: #9ca3af;
  text-align: center;
  line-height: 50px;
  padding-right: 4px;
}

.day-header {
  text-align: center;
  padding: 8px 4px;
  border-left: 1px solid #e5e7eb;
  background: #fff;
}
.day-header.today {
  background: #eef1ff;
  border-bottom: 2px solid #4f6ef7;
}
.day-name { font-size: 13px; font-weight: 600; color: #374151; }
.day-date { font-size: 11px; color: #9ca3af; margin-top: 2px; }
.day-header.today .day-name { color: #4f6ef7; }

.day-cell {
  border-left: 1px solid #f3f4f6;
  border-top: 1px solid #f3f4f6;
  min-height: 50px;
  padding: 2px;
  background: #fff;
}
.day-cell.today-cell {
  background: #fafbff;
}

.schedule-item {
  border-radius: 4px;
  padding: 2px 4px;
  margin-bottom: 2px;
  font-size: 10px;
  line-height: 1.4;
  overflow: hidden;
}
.schedule-item .s-name {
  font-weight: 600;
  color: #333;
  display: block;
}
.schedule-item .s-time {
  color: #666;
  display: block;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  border-top: 1px solid #e5e7eb;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}
.nav-item {
  flex: 1;
  text-align: center;
  padding: 8px 0;
  font-size: 11px;
  color: #9ca3af;
}
.nav-item.active { color: #4f6ef7; }
.nav-item .nav-icon { font-size: 20px; display: block; margin-bottom: 2px; }
.nav-item .nav-label { display: block; }
