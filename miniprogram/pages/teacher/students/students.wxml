<view class="page">
  <view class="page-bar">
    <view class="page-title">学生管理</view>
    <button class="btn btn-primary btn-sm" bindtap="showAddModal">+ 添加</button>
  </view>

  <view wx:if="{{loading}}" style="text-align:center;padding:40px;color:#9ca3af;">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{students.length === 0}}" class="card">
    <view class="empty-state">
      <view class="empty-icon">👥</view>
      <text class="empty-text">还没有学生，点击右上角添加</text>
    </view>
  </view>

  <view wx:else>
    <view class="card" wx:for="{{students}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <view class="list-item">
        <view style="width:40px;height:40px;border-radius:50%;background:#eef1ff;display:flex;align-items:center;justify-content:center;font-size:18px;color:#4f6ef7;">{{item.name[0]}}</view>
        <view class="item-main">
          <view class="item-title">{{item.name}}
            <text wx:if="{{!item.is_active}}" class="tag tag-danger" style="margin-left:6px;">已停用</text>
          </view>
          <view class="item-sub">{{item.grade}} · {{item.subject}} · ¥{{item.default_fee}}/h · {{item.default_people_type}}</view>
          <view wx:if="{{item.phone}}" class="item-sub">{{item.phone}}</view>
        </view>
        <view style="font-size:18px;">→</view>
      </view>
    </view>
  </view>
  <view style="height:20px;"></view>

  <!-- 添加学生弹窗 -->
  <view wx:if="{{showModal}}" class="modal-overlay" bindtap="hideModal">
    <view class="modal-content" catchtap="noop">
      <view style="font-size:18px;font-weight:600;margin-bottom:16px;">添加学生</view>
      <view class="form-group">
        <text class="form-label">姓名 *</text>
        <input class="form-input" value="{{form.name}}" placeholder="请输入姓名" bindinput="onFormInput" data-field="name" />
      </view>
      <view class="form-group">
        <text class="form-label">手机号</text>
        <input class="form-input" value="{{form.phone}}" placeholder="家长手机号，用于学生登录" bindinput="onFormInput" data-field="phone" />
      </view>
      <view class="grid-2">
        <view class="form-group grid-2-item">
          <text class="form-label">年级</text>
          <input class="form-input" value="{{form.grade}}" placeholder="如: 高一" bindinput="onFormInput" data-field="grade" />
        </view>
        <view class="form-group grid-2-item">
          <text class="form-label">科目</text>
          <input class="form-input" value="{{form.subject}}" placeholder="如: 数学" bindinput="onFormInput" data-field="subject" />
        </view>
      </view>
      <view class="grid-2">
        <view class="form-group grid-2-item">
          <text class="form-label">课时费(元/h)</text>
          <input class="form-input" type="number" value="{{form.default_fee}}" bindinput="onFormInput" data-field="default_fee" />
        </view>
        <view class="form-group grid-2-item">
          <text class="form-label">上课类型</text>
          <picker mode="selector" range="{{PEOPLE_TYPES}}" value="{{peopleTypeIndex}}" bindchange="onPeopleTypeChange">
            <view class="form-input">{{form.default_people_type}}</view>
          </picker>
        </view>
      </view>
      <view class="flex gap-8 mt-16">
        <button class="btn btn-outline" style="flex:1;" bindtap="hideModal">取消</button>
        <button class="btn btn-primary" style="flex:1;" bindtap="addStudent">保存</button>
      </view>
    </view>
  </view>
</view>
