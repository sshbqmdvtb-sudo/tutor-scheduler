<view class="page">
  <view class="page-bar">
    <view class="page-title">上课记录</view>
    <button class="btn btn-primary btn-sm" bindtap="showAddModal">+ 记录</button>
  </view>

  <!-- 筛选 -->
  <view class="card" style="padding:12px;margin-bottom:0;">
    <view class="flex gap-8">
      <picker mode="selector" range="{{studentNames}}" value="{{filterStudentIndex}}" bindchange="onStudentFilterChange" style="flex:1;">
        <view class="form-input">{{filterStudentIndex === 0 ? '全部学生' : studentNames[filterStudentIndex]}}</view>
      </picker>
      <picker mode="date" fields="month" value="{{filterMonth}}" bindchange="onMonthFilterChange" style="flex:1;">
        <view class="form-input">{{filterMonth}}</view>
      </picker>
    </view>
  </view>

  <view wx:if="{{loading}}" style="text-align:center;padding:40px;color:#9ca3af;">加载中...</view>

  <view wx:elif="{{records.length === 0}}" class="card">
    <view class="empty-state">
      <view class="empty-icon">📝</view>
      <text class="empty-text">暂无上课记录</text>
    </view>
  </view>

  <view wx:else class="card" wx:for="{{records}}" wx:key="id">
    <view class="list-item">
      <view style="width:40px;height:40px;border-radius:50%;background:#eef1ff;display:flex;align-items:center;justify-content:center;font-size:18px;color:#4f6ef7;">{{item.student_name ? item.student_name[0] : '?'}}</view>
      <view class="item-main">
        <view class="item-title">{{item.student_name}}
          <text class="tag {{item.is_settled ? 'tag-success' : 'tag-warning'}}" style="margin-left:6px;">{{item.is_settled ? '已结' : '未结'}}</text>
        </view>
        <view class="item-sub">{{item.date}} {{item.start_time}}-{{item.end_time}}</view>
        <view class="item-sub">{{item.people_type}} · {{formatMinutes(item.duration_minutes)}} · ¥{{item.total_fee}}</view>
        <view wx:if="{{item.content}}" class="text-sm" style="color:#6b7280;margin-top:2px;">{{item.content}}</view>
      </view>
      <button class="btn btn-danger btn-sm" data-id="{{item.id}}" bindtap="deleteRecord">删除</button>
    </view>
  </view>

  <view style="height:20px;"></view>

  <!-- 添加弹窗 -->
  <view wx:if="{{showAddModal}}" class="modal-overlay" bindtap="hideModals">
    <view class="modal-content" catchtap="noop">
      <view style="font-size:18px;font-weight:600;margin-bottom:16px;">记录上课</view>
      <view class="form-group">
        <text class="form-label">学生 *</text>
        <picker mode="selector" range="{{realStudentNames}}" value="{{formStudentIndex}}" bindchange="onFormStudentChange">
          <view class="form-input">{{formStudentIndex >= 0 ? realStudentNames[formStudentIndex] : '请选择学生'}}</view>
        </picker>
      </view>
      <view class="form-group">
        <text class="form-label">日期</text>
        <picker mode="date" value="{{form.date}}" bindchange="onFormDateChange">
          <view class="form-input">{{form.date}}</view>
        </picker>
      </view>
      <view class="grid-2">
        <view class="form-group grid-2-item">
          <text class="form-label">开始</text>
          <picker mode="time" value="{{form.start_time}}" bindchange="onFormStartChange">
            <view class="form-input">{{form.start_time}}</view>
          </picker>
        </view>
        <view class="form-group grid-2-item">
          <text class="form-label">结束</text>
          <picker mode="time" value="{{form.end_time}}" bindchange="onFormEndChange">
            <view class="form-input">{{form.end_time}}</view>
          </picker>
        </view>
      </view>
      <view class="grid-2">
        <view class="form-group grid-2-item">
          <text class="form-label">类型</text>
          <picker mode="selector" range="{{PEOPLE_TYPES}}" value="{{formPeopleTypeIndex}}" bindchange="onFormPeopleTypeChange">
            <view class="form-input">{{form.people_type}}</view>
          </picker>
        </view>
        <view class="form-group grid-2-item">
          <text class="form-label">人数</text>
          <input class="form-input" type="number" value="{{form.people_count}}" bindinput="onFormPeopleCountInput" />
        </view>
      </view>
      <view class="grid-2">
        <view class="form-group grid-2-item">
          <text class="form-label">课时费(元/h)</text>
          <input class="form-input" type="number" value="{{form.fee_per_hour}}" bindinput="onFormFeeInput" />
        </view>
        <view class="form-group grid-2-item">
          <text class="form-label">总费用</text>
          <input class="form-input" type="number" value="{{form.total_fee}}" bindinput="onFormTotalFeeInput" />
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">内容</text>
        <input class="form-input" value="{{form.content}}" placeholder="选填" bindinput="onFormContentInput" />
      </view>
      <view class="flex gap-8 mt-16">
        <button class="btn btn-outline" style="flex:1;" bindtap="hideModals">取消</button>
        <button class="btn btn-primary" style="flex:1;" bindtap="addRecord">保存</button>
      </view>
    </view>
  </view>
</view>
